datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  email     String     @unique
  password  String
  name      String?
  role      String     @default("user")
  createdAt DateTime   @default(now())

  favorites Favorite[]
  ratings   Rating[]

  @@map("users")
}

model Movie {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String     @db.Text
  thumbnail   String
  youtubeUrl  String
  category    String
  year        Int
  duration    Int
  views       Int        @default(0)
  matchRate   Int        @default(100)
  ageRating   String     @default("PG-13")
  university  String?

  favorites Favorite[]
  ratings   Rating[]
  crew      MovieCrew[]
  bts       MovieBts?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([category])
  @@index([university])
  @@index([title])
  @@map("movies")
}

model CrewMember {
  id        String      @id @default(uuid()) @db.Uuid
  name      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  movieCrews MovieCrew[]

  @@map("crew_members")
}

model MovieCrew {
  id           String     @id @default(uuid()) @db.Uuid
  movieId      String     @db.Uuid
  crewMemberId String     @db.Uuid
  role         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  movie        Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  crewMember   CrewMember @relation(fields: [crewMemberId], references: [id], onDelete: Cascade)

  @@unique([movieId, crewMemberId, role])
  @@map("movie_crews")
}

model MovieBts {
  id        String   @id @default(uuid()) @db.Uuid
  movieId   String   @unique @db.Uuid
  btsVideo  String[] @default([])
  btsPhotos String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@map("movie_bts")
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  movieId   String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  

  @@unique([userId, movieId])
  @@map("favorites")
}

model Rating {
  id        String   @id @default(uuid()) @db.Uuid
  movieId   String   @db.Uuid
  userId    String   @db.Uuid
  stars     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, movieId])
  @@map("ratings")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("categories")
}

model University {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("universities")
}

model AgeRating {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("age_ratings")
}

